# Data Analyst Agent — production environment template
# Copy to .env and fill in values before running docker compose.
#
# The f1di platform stack (postgres, ollama, qdrant, grafana) must be running
# and have created the f1di_default Docker network before starting this stack.

# ── Ports ────────────────────────────────────────────────────────────────────
# f1di platform api occupies 8080; we bind to 8081 to avoid conflict.
API_HOST_PORT=8081
UI_HOST_PORT=8501

# ── LLM (Ollama on the f1di network) ─────────────────────────────────────────
LLM_ENABLED=true
LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=
LLM_MODEL=llama3.1:latest
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=120
LLM_MAX_TOOL_CALLS=4
LLM_MAX_REPAIR_ATTEMPTS=1

# ── RAG ───────────────────────────────────────────────────────────────────────
# Set to 1 after running scripts/ingest_corpus.sh on the server.
ENABLE_RAG=0
LLM_RAG_MAX_CHUNKS=6
LLM_RAG_MAX_CHARS_PER_CHUNK=1200
LLM_RAG_MIN_SCORE=0.25

# ── Analysis context sent to LLM ─────────────────────────────────────────────
LLM_ANALYSIS_SAMPLE_ROWS=5000
LLM_ANALYSIS_PREVIEW_ROWS=5
LLM_ANALYSIS_MAX_COLUMNS=80
LLM_ANALYSIS_MAX_CORRELATIONS=20
LLM_ANALYSIS_MAX_CATEGORICAL_ASSOCIATIONS=10

# ── Observability ─────────────────────────────────────────────────────────────
# Fraction of LLM responses sampled for groundedness judging (0 = off).
LLM_JUDGE_SAMPLE_RATE=0.05

# ── HuggingFace (sentence-transformers for RAG embeddings) ───────────────────
TRANSFORMERS_OFFLINE=1
HF_HOME=/app/.cache/huggingface

# ── Streamlit ────────────────────────────────────────────────────────────────
CHAT_TIMEOUT_SECONDS=300
