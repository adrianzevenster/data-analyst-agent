FROM python:3.11-slim

WORKDIR /app

# Avoid slow/noisy pip checks
ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# libgomp1 provides libgomp.so.1, the OpenMP runtime lightgbm's compiled
# extension dlopen()s at import time - without it the API container fails
# to start as soon as anything imports app.analytics.ml_train.
RUN apt-get update && apt-get install -y --no-install-recommends libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Install API deps first (maximizes docker layer cache)
COPY requirements-api.txt .
RUN pip install --no-cache-dir --timeout=120 -r requirements-api.txt

# Copy the app
COPY . .

ENV PYTHONPATH=/app
ENV DATA_DIR=/app/data

# Bake the sentence embedding model into the image so it's available offline
# on a fresh server where the HF bind-mount volume is still empty.
# /app/hf_cache is NOT volume-mounted by either compose file, so this cache
# is always present regardless of what the host mounts at /app/.cache/huggingface.
ENV HF_HOME=/app/hf_cache
RUN python -c "from sentence_transformers import SentenceTransformer; \
    SentenceTransformer('sentence-transformers/all-MiniLM-L6-v2')" \
    && echo "Embedding model cached at /app/hf_cache"

EXPOSE 8080

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8080"]
