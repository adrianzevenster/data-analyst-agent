FROM python:3.11-slim

WORKDIR /app

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends libgomp1 \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-api.txt .
RUN pip install --no-cache-dir --timeout=120 -r requirements-api.txt

# ── Bake embedding model BEFORE copying app code ──────────────────────────────
# This layer is cached right after pip install, so it only re-runs when
# requirements-api.txt changes — NOT on every source-code push.
# Without this ordering, COPY . . (below) invalidates this layer on every
# commit, causing the model download to be CANCELLED by failed sibling builds.
ENV HF_HOME=/app/hf_cache
ENV HF_HUB_OFFLINE=0
RUN python -c "from sentence_transformers import SentenceTransformer; \
    SentenceTransformer('sentence-transformers/all-MiniLM-L6-v2')" \
    && echo "Embedding model cached at /app/hf_cache"

# Copy the app AFTER the model is cached
COPY . .

ENV PYTHONPATH=/app
ENV DATA_DIR=/app/data
# At runtime, hub is offline — model is already baked in above
ENV HF_HUB_OFFLINE=1

EXPOSE 8080

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8080"]
